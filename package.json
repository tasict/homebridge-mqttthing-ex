{
  "name": "homebridge-mqttthing-ex",
  "displayName": "MQTT Thing EX",
  "version": "2.0.0-beta.1",
  "description": "Homebridge plugin supporting various HomeKit services over MQTT. A modern TypeScript rewrite of homebridge-mqttthing with a fully compatible configuration format.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "homebridge": "^1.8.0 || ^2.0.0",
    "node": "^18.17.0 || ^20.9.0 || ^22.10.0 || ^24.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tasict/homebridge-mqttthing-ex.git"
  },
  "keywords": [
    "homebridge-plugin",
    "MQTT",
    "homekit",
    "Siri",
    "IoT",
    "ESPurna",
    "tasmota",
    "light",
    "light bulb",
    "switch",
    "outlet",
    "motion sensor",
    "occupancy sensor",
    "light sensor",
    "contact sensor",
    "doorbell",
    "smoke sensor",
    "security system",
    "humidity sensor",
    "temperature sensor",
    "garage door",
    "stateless programmable switch",
    "fan",
    "fanv2",
    "microphone",
    "speaker",
    "window covering",
    "blind",
    "leak sensor",
    "lock mechanism",
    "lock",
    "window",
    "door",
    "air quality sensor",
    "carbondioxide sensor",
    "air pressure sensor",
    "weather station",
    "valve",
    "sprinkler",
    "shower",
    "faucet",
    "thermostat",
    "heater cooler",
    "irrigation system",
    "air purifier",
    "dehumidifier"
  ],
  "author": "tasict",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/tasict/homebridge-mqttthing-ex/issues"
  },
  "homepage": "https://github.com/tasict/homebridge-mqttthing-ex#readme",
  "files": [
    "dist",
    "codecs",
    "config.schema.json",
    "docs",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "dependencies": {
    "fakegato-history": "^0.6.7",
    "jsonpath": "^1.3.0",
    "mqtt": "^5.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@homebridge/hap-nodejs": "^2.0.0",
    "@types/jsonpath": "^0.2.4",
    "@types/node": "^22.0.0",
    "aedes": "^0.51.0",
    "eslint": "^9.0.0",
    "homebridge": "^2.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
